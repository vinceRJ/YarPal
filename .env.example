# Copiez ce fichier en .env et remplissez vos propres clés
# Ne commitez JAMAIS le fichier .env — il est listé dans .gitignore

# Obligatoire — Chef d'orchestre de LarPal
OPENAI_API_KEY=sk-...

# Obligatoire — Analyste de fond (analyse stratégique approfondie)
GEMINI_API_KEY=AIza...

# Obligatoire — Recherche d'actualités financières
TAVILY_API_KEY=tvly-...

# Optionnel — Remplace Tavily pour des news de niveau professionnel (abonnement payant)
# PERPLEXITY_API_KEY=pplx-...

# Mot de passe d'accès à votre instance LarPal — choisissez-en un fort
LARPAL_PASSWORD=changez_moi

# Votre prénom, affiché dans l'interface
USER_NAME=VotrePrenom
